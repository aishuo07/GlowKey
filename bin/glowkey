#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
RELEASE_BIN="$ROOT_DIR/.build/release/glowkey"
DEBUG_BIN="$ROOT_DIR/.build/debug/glowkey"
RELEASE_SHADE="$ROOT_DIR/.build/release/glowkey-shade"
DEBUG_SHADE="$ROOT_DIR/.build/debug/glowkey-shade"
RELEASE_HOTKEYS="$ROOT_DIR/.build/release/glowkey-hotkeys"
DEBUG_HOTKEYS="$ROOT_DIR/.build/debug/glowkey-hotkeys"
RELEASE_DAEMON="$ROOT_DIR/.build/release/glowkey-daemon"
DEBUG_DAEMON="$ROOT_DIR/.build/debug/glowkey-daemon"
RELEASE_MENUBAR="$ROOT_DIR/.build/release/glowkey-menubar"
DEBUG_MENUBAR="$ROOT_DIR/.build/debug/glowkey-menubar"

if [ -x "$DEBUG_BIN" ] && [ -x "$DEBUG_SHADE" ] && [ -x "$DEBUG_HOTKEYS" ] && [ -x "$DEBUG_DAEMON" ] && [ -x "$DEBUG_MENUBAR" ]; then
  if [ ! -x "$RELEASE_BIN" ] || [ "$DEBUG_BIN" -nt "$RELEASE_BIN" ]; then
    exec "$DEBUG_BIN" "$@"
  fi
fi

if [ -x "$RELEASE_BIN" ] && [ -x "$RELEASE_SHADE" ] && [ -x "$RELEASE_HOTKEYS" ] && [ -x "$RELEASE_DAEMON" ] && [ -x "$RELEASE_MENUBAR" ]; then
  exec "$RELEASE_BIN" "$@"
fi

swift build --package-path "$ROOT_DIR"
exec "$DEBUG_BIN" "$@"
